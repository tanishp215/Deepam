generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pledge {
  id        Int      @id @default(autoincrement())
  templeId  String
  eventName String
  name      String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([templeId])
}
